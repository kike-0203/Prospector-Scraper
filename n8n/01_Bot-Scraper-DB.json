    {
      "parameters": {
        "jsCode": "const cpsIds = $('CODE_ArmarCampanaDesdeCPs').first().json.cps_ids || [];\n\nreturn cpsIds.map(id => ({\n  json: {\n    id,\n    usado: true,\n    ultimo_uso: new Date().toISOString()\n  }\n}));"
