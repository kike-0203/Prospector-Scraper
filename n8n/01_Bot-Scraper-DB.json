    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').first().json;\nconst input = webhook.body || webhook;\n\nconst cps = $json.items || [];\n\nif (cps.length === 0) {\n  throw new Error('No hay CPs disponibles para esa alcaldía.');\n}\n\nconst nicho = input.nicho || 'Tamales';\nconst alcaldia = input.alcaldia || 'Coyoacan';\nconst ciudad = 'CDMX';\n\nconst cpTexto = cps.map(x => x.cp).join(',');\n\nconst cleanNicho = nicho.toLowerCase().replace(/\\s+/g, '_');\nconst cleanAlcaldia = alcaldia.toLowerCase().replace(/\\s+/g, '_');\n\nconst fecha = new Date()\n  .toISOString()\n  .replace(/[-:T.Z]/g, '')\n  .slice(0, 12);\n\nreturn [{\n  json: {\n    hoja: `${cleanNicho}_${cleanAlcaldia}_${fecha}`,\n    nicho,\n    alcaldia,\n    ciudad,\n    cp: cpTexto,\n    cps_ids: cps.map(x => x.id),\n    accion: 'iniciar_scraping'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
