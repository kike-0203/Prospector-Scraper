    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\n// Si ya viene como búsqueda individual, solo la dejamos pasar\nif (data.campana_id && data.cp && data.combinacion) {\n  return $input.all();\n}\n\n// Si viene como campaña completa, separa los CP\nconst cps = String(data.cp || '')\n  .split(',')\n  .map(cp => cp.trim())\n  .filter(Boolean);\n\nreturn cps.map(cp => ({\n  json: {\n    campana_id: data.campana_id,\n    cp,\n    combinacion: `${data.nicho} cerca de ${cp} ${data.alcaldia} ${data.ciudad}`,\n    estado: 'pendiente'\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
