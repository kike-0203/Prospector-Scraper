      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst data = input.body || input;\n\nconst hoja = data.hoja || '';\nconst url_sheets = data.url_sheets || '';\nconst webhook_callback = data.webhook_callback || '';\n\nconst nicho = data.nicho || '';\nconst alcaldia = data.alcaldia || '';\nconst ciudad = data.ciudad || '';\nconst cp = data.cp || '';\n\nconst accion = data.accion || 'iniciar_scraping';\n\nconst documentId = url_sheets\n  ? (url_sheets.match(/\\/d\\/([a-zA-Z0-9-_]+)/)?.[1] || '')\n  : '';\n\nreturn [\n  {\n    json: {\n      hoja,\n      documentId,\n      webhook_callback,\n      nicho,\n      alcaldia,\n      ciudad,\n      cp,\n      accion\n    }\n  }\n];"
